# Postgres (Supabase: Project Settings → Database → Connection string → URI)
# Must include a real host (e.g. db.<project-ref>.supabase.co). Empty host → psycopg "nodename nor servname".
# If the DB password contains @ # etc., URL-encode it or use the "Connection pooling" string from Supabase.
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# supabase db push (CLI) — if you see "permission denied to alter role cli_login_postgres":
# export SUPABASE_DB_PASSWORD='<Database password from same Supabase screen>'
# Or run migration SQL manually in Supabase → SQL Editor.

# Optional alias
# SUPABASE_DB_URL=

# Set to 1 to skip running migration on startup (e.g. CI or migrations via supabase CLI)
# SKIP_SCHEMA_INIT=0

# LOG_LEVEL=INFO

# Supabase Auth (optional): /v1/auth/login calls GoTrue when URL + key are set.
# URL: Project Settings → same project ref as in DATABASE_URL host db.<ref>.supabase.co
# Key: Settings → API Keys → Publishable (sb_publishable_...) or legacy anon JWT.
# SUPABASE_URL=https://<project-ref>.supabase.co
# SUPABASE_ANON_KEY=
# Do not put the Secret (service_role / sb_secret_) key here unless you add server code that needs it.

# Feed distance sort / max_distance_miles filter (e.g. UW–Madison campus)
# CAMPUS_LAT=43.0731
# CAMPUS_LNG=-89.4012