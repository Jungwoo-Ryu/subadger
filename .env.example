# Supabase Auth for POST /v1/auth/login (optional). URL can be omitted if DATABASE_URL
# uses db.<project-ref>.supabase.co — the API will infer https://<project-ref>.supabase.co
# SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# SUPABASE_ANON_KEY=eyJ...   # Project Settings → API → anon public

# Postgres (Supabase: Project Settings → Database → URI, or local supabase)
# Used by FastAPI startup schema bootstrap (db_init) when public.profiles is missing.
# If the password contains ! @ : # etc., either paste the URI from Supabase as-is or
# percent-encode those characters (e.g. ! → %21). FastAPI normalizes common cases.
# Supabase: host contains supabase.co → app appends sslmode=require if missing.
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# Optional alias
# SUPABASE_DB_URL=

# Set to 1 to skip running migration on startup (e.g. CI or migrations via supabase CLI)
# SKIP_SCHEMA_INIT=0

# LOG_LEVEL=INFO

# CORS (comma-separated origins, or * for dev)
# CORS_ORIGINS=*

# School email suffix for POST /v1/auth/check-email
# ALLOWED_EMAIL_SUFFIX=@wisc.edu

# Demo login POST /v1/auth/login — paste profiles.id from Supabase Table editor (see docs/DEMO_MOBILE.md)
# If set, login never hits the DB. If unset + AUTH_DEMO_AUTO_FIRST_PROFILE=1, server reads DB;
# on DB error, same AUTH_DEMO_USER_ID is used as fallback when set.
# AUTH_DEMO_EMAIL=system@wisc.edu
# AUTH_DEMO_PASSWORD=system
# AUTH_DEMO_USER_ID=
# AUTH_DEMO_AUTO_FIRST_PROFILE=1
