# Expo public environment variables only.
# Do not put DATABASE_URL, service_role, or DB passwords in this file.

# FastAPI base URL (no trailing slash).
# - Deployed: https://your-project.vercel.app
# - Local: http://127.0.0.1:8000 (uvicorn main:app --host 0.0.0.0 --port 8000)
# - Physical device + local API: your computer's LAN IP
EXPO_PUBLIC_API_URL=http://127.0.0.1:8000

# Email confirmation redirect (optional). If unset, defaults to EXPO_PUBLIC_API_URL + /auth/email-confirmed
# Supabase → Authentication → URL Configuration → Redirect URLs must include this exact URL, e.g.:
#   https://your-project.vercel.app/auth/email-confirmed
#   http://192.168.0.12:8000/auth/email-confirmed   (phone on same Wi‑Fi as dev API)
# EXPO_PUBLIC_AUTH_REDIRECT_URL=

# Supabase client configuration for the mobile app (Expo: only EXPO_PUBLIC_*).
# Same Publishable key as backend SUPABASE_ANON_KEY (never put Secret / service_role here).
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_your_key_here
